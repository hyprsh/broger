---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';

const photos = [
  { src: '/images/photos/king-george.jpg', alt: 'King George im Vormarsch', span: true },
  { src: '/images/photos/race-1.jpg', alt: 'Skikjöring-Rennen am White Turf' },
  { src: '/images/photos/race-3.jpg', alt: 'Auf dem gefrorenen St. Moritzersee' },
  { src: '/images/photos/race-2.jpg', alt: 'Skikjöring in voller Fahrt' },
  { src: '/images/photos/race-4.jpg', alt: 'Rennszene am White Turf' },
  { src: '/images/photos/race-5.jpg', alt: 'Skikjöring St. Moritz' },
  { src: '/images/photos/hero.jpg', alt: 'Jakob Broger beim Skikjöring', span: true },
];
---

<Base title="Impressionen">
  <PageHeader title="Impressionen" lead="Bilder vom White Turf St. Moritz und aus 24 Saisons Skikjöring." />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="grid auto-rows-[220px] grid-cols-2 gap-4 md:grid-cols-3">
      {photos.map((p) => (
        <figure class:list={['group overflow-hidden rounded-xl', p.span ? 'col-span-2 row-span-2' : '']}>
          <img
            src={p.src}
            alt={p.alt}
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </figure>
      ))}
    </div>
    <p class="mt-6 text-sm text-ink/50">
      Fotos: White Turf St. Moritz. Weitere Bilder folgen.
    </p>
  </section>
</Base>
