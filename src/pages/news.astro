---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { news } from '../data/site.js';
---

<Base title="News">
  <PageHeader title="News" lead="Berichte, Interviews und Rückblicke aus der Skikjöring-Laufbahn." />

  <section class="mx-auto max-w-3xl px-5 py-16">
    <div class="space-y-12">
      {news.map((n) => (
        <article class="border-b border-frost pb-12 last:border-0">
          <time class="font-display text-xs uppercase tracking-[0.25em] text-glacier">{n.date}</time>
          <h2 class="mt-2 text-2xl font-semibold leading-snug">{n.title}</h2>
          <div class="mt-4 space-y-4 leading-relaxed text-ink/80">
            {n.body.map((p) => <p>{p}</p>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
