---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { topHorses, stats } from '../data/site.js';

// Horses ordered by wins for the results overview.
const ranked = [...stats.rows].sort((a, b) => Number(b[2]) - Number(a[2]));
---

<Base title="Resultate">
  <PageHeader
    title="Resultate"
    lead="Karriere-Übersicht 1996–2022 — die Gespanne, die Erfolge und die Krone als König vom Engadin."
  />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="text-xl font-semibold">Erfolgreichste Gespanne</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {topHorses.map((h) => (
        <div class="rounded-xl border border-frost bg-white p-6">
          <div class="flex items-baseline justify-between">
            <h3 class="text-xl font-semibold">{h.name}</h3>
            <span class="text-sm text-glacier">{h.years}</span>
          </div>
          <p class="mt-2 text-ink/75">{h.note}</p>
          {(h.trainer || h.owner) && (
            <p class="mt-3 text-sm text-ink/55">
              {h.owner}{h.owner && h.trainer ? ' · ' : ''}{h.trainer && `Trainer ${h.trainer}`}
            </p>
          )}
        </div>
      ))}
    </div>

    <h2 class="mt-16 text-xl font-semibold">Siege nach Pferd</h2>
    <div class="mt-6 space-y-3">
      {ranked.filter((r) => Number(r[2]) > 0).map((r) => {
        const wins = Number(r[2]);
        const starts = Number(r[1]);
        const pct = Math.round((wins / starts) * 100);
        return (
          <div class="rounded-lg border border-frost bg-white p-4">
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium">{r[0]}</span>
              <span class="text-ink/60">{wins} Siege / {starts} Starts</span>
            </div>
            <div class="mt-2 h-2 overflow-hidden rounded-full bg-frost">
              <div class="h-full rounded-full bg-glacier" style={`width:${pct}%`}></div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="mt-16 rounded-xl border border-glacier/30 bg-glacier/5 p-6">
      <h3 class="font-display text-lg font-semibold text-glacier-deep">König vom Engadin</h3>
      <p class="mt-2 text-ink/80">
        Der jährliche Titel der Credit Suisse / UBS Skikjöring Trophy geht an den
        erfolgreichsten Skikjöringfahrer der Saison. Jakob Broger gewann die Krone
        <strong>elf Mal</strong> — ein bis heute prägender Rekord am White Turf.
      </p>
    </div>
  </section>
</Base>
