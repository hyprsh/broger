---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { stats, highlights } from '../data/site.js';
---

<Base title="Statistik">
  <PageHeader title="Statistik" lead="Alle Starts von 1996 bis 2022, aufgeschlüsselt nach Pferd und Platzierung." />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <!-- Headline numbers -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {highlights.map((h) => (
        <div class="rounded-xl border border-frost bg-white p-6 text-center">
          <div class="font-display text-3xl font-bold text-glacier">{h.value}</div>
          <div class="mt-1 text-xs uppercase tracking-widest text-ink/55">{h.label}</div>
        </div>
      ))}
    </div>

    <!-- Stats table -->
    <div class="mt-12 overflow-x-auto rounded-xl border border-frost bg-white">
      <table class="w-full min-w-[640px] text-sm">
        <thead>
          <tr class="bg-ink text-snow">
            {stats.columns.map((c, i) => (
              <th class:list={['px-4 py-3 font-display font-medium uppercase tracking-wide', i === 0 ? 'text-left' : 'text-center']}>
                {c}
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-frost">
          {stats.rows.map((row) => (
            <tr class="transition hover:bg-snow">
              {row.map((cell, i) => (
                <td class:list={['px-4 py-3', i === 0 ? 'text-left font-medium' : 'text-center', i === 2 && cell ? 'font-semibold text-glacier' : '']}>
                  {cell}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-ink bg-frost/40 font-display font-semibold">
            {stats.total.map((cell, i) => (
              <td class:list={['px-4 py-3', i === 0 ? 'text-left' : 'text-center']}>{cell}</td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
    <p class="mt-4 text-sm text-ink/55">
      Total 61 Starts · 24 Siege · 11 Titel als König vom Engadin.
    </p>
  </section>
</Base>
