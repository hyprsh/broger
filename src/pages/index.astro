---
import Base from '../layouts/Base.astro';
import { Image, getImage } from 'astro:assets';
import {
  profile,
  career,
  highlights,
  stats,
  topHorses,
  sponsoring,
  partners,
  retirement,
} from '../data/site.js';

const base = import.meta.env.BASE_URL;
const logo = (p) => `${base}images/logos/${p}`; // logos stay in public/

// Photos live in src/assets/photos and are optimized by Astro at build time.
const photoMods = import.meta.glob('../assets/photos/*.jpg', { eager: true, import: 'default' });
const photo = (name) => photoMods[`../assets/photos/${name}`];

const personal = [
  { label: 'Wohnort', value: profile.location },
  { label: 'Geboren', value: profile.born },
  { label: 'Familie', value: profile.family },
  { label: 'Beruf', value: profile.job },
];

const ranked = [...stats.rows]
  .filter((r) => Number(r[2]) > 0)
  .sort((a, b) => Number(b[2]) - Number(a[2]));

// Editorial collage — `cls` controls the grid span of each tile (4-col grid).
const gallery = [
  { name: 'king-george.jpg', alt: 'King George im Vormarsch', cls: 'col-span-2 row-span-2' },
  { name: 'race-1.jpg', alt: 'Skikjöring-Rennen am White Turf', cls: 'col-span-2' },
  { name: 'race-3.jpg', alt: 'Auf dem gefrorenen St. Moritzersee', cls: '' },
  { name: 'race-4.jpg', alt: 'Rennszene am White Turf', cls: '' },
  { name: 'race-2.jpg', alt: 'Skikjöring in voller Fahrt', cls: '' },
  { name: 'race-5.jpg', alt: 'Skikjöring St. Moritz', cls: '' },
  { name: 'hero.jpg', alt: 'Jakob Broger im Rennen', cls: 'col-span-2' },
];

// A full-size WebP per gallery photo, used by the lightbox.
const galleryFull = {};
for (const g of gallery) {
  galleryFull[g.name] = (await getImage({ src: photo(g.name), width: 2000, format: 'webp', quality: 80 })).src;
}
---

<Base>
  <!-- ===== HERO ===== -->
  <section id="top" class="relative isolate flex min-h-screen items-center overflow-hidden">
    <Image
      src={photo('hero.jpg')}
      alt="Jakob Broger beim Skikjöring am White Turf St. Moritz"
      class="parallax-img -z-10 object-center"
      widths={[1200, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      data-parallax="0.18"
      data-zoom="0.14"
      data-pointer="22"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-ink/70 via-ink/45 to-ink/85"></div>

    <div class="mx-auto w-full max-w-6xl px-5 pt-24 text-snow" data-parallax="-0.16" data-fade data-pointer="-9">
      <p class="font-display text-sm uppercase tracking-[0.4em] text-snow/80">White Turf · St. Moritz</p>
      <h1 class="mt-4 text-5xl font-bold leading-[0.95] sm:text-7xl lg:text-8xl">
        Jakob<br /><span class="text-gold">Broger</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg text-snow/90 sm:text-xl">
        Von 1996 bis 2022 auf dem gefrorenen St. Moritzersee<br />
        24 Siege und elf Mal die Krone als König vom Engadin.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#resultate" class="rounded-full bg-glacier px-7 py-3.5 text-sm font-semibold text-snow shadow-lg shadow-glacier/30 transition hover:bg-glacier-deep">
          Resultate ansehen
        </a>
        <a href="#person" class="rounded-full border border-snow/40 px-7 py-3.5 text-sm font-semibold text-snow backdrop-blur-sm transition hover:bg-snow/10">
          Zur Person
        </a>
      </div>
    </div>

    <a href="#zahlen" aria-label="Nach unten scrollen" class="absolute bottom-7 left-1/2 -translate-x-1/2 text-snow/70 transition hover:text-snow">
      <svg class="h-7 w-7 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 5v14M19 12l-7 7-7-7" />
      </svg>
    </a>
  </section>

  <!-- ===== STATS BAND ===== -->
  <section id="zahlen" class="border-y border-frost bg-white">
    <div class="mx-auto grid max-w-6xl grid-cols-2 divide-frost md:grid-cols-4 md:divide-x">
      {highlights.map((h) => (
        <div class="reveal px-5 py-12 text-center">
          <div class="font-display text-5xl font-bold text-glacier sm:text-6xl" data-count={h.value}>{h.value}</div>
          <div class="mt-2 text-xs uppercase tracking-[0.2em] text-ink/55">{h.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== RÜCKTRITT / STATEMENT ===== -->
  <section id="ruecktritt" class="relative isolate scroll-mt-16 overflow-hidden bg-ink py-28 text-snow">
    <Image
      src={photo('race-5.jpg')}
      alt=""
      class="parallax-img -z-10 opacity-25"
      widths={[1200, 2000]}
      sizes="100vw"
      loading="lazy"
      data-parallax="0.14"
      data-zoom="0.1"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-ink via-ink/85 to-ink"></div>

    <div class="reveal mx-auto max-w-3xl px-5 text-center">
      <p class="font-display text-xs uppercase tracking-[0.3em] text-gold">{retirement.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-bold sm:text-6xl">{retirement.title}</h2>
      <div class="mx-auto mt-8 max-w-2xl space-y-5 text-lg leading-relaxed text-snow/85">
        {retirement.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <p class="mt-10 font-display text-2xl text-gold">{retirement.signoff}</p>
      <p class="mt-2 text-sm uppercase tracking-[0.2em] text-snow/70">{retirement.signature}</p>
    </div>
  </section>

  <!-- ===== PERSON ===== -->
  <section id="person" class="mx-auto max-w-6xl scroll-mt-20 px-5 py-24">
    <div class="reveal max-w-2xl">
      <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Personalien</p>
      <h2 class="mt-3 text-3xl font-bold sm:text-5xl">Der erste Flachländer auf dem Eis</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink/75">
        In den 1990er-Jahren brach Jakob „Köbi“ Broger als erster Flachländer in
        die Domäne der Engadiner ein und prägte das Skikjöring über mehr als
        zwei Jahrzehnte.
      </p>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="reveal">
        <Image src={photo('race-2.jpg')} alt="Jakob Broger beim Skikjöring" class="aspect-[4/5] w-full rounded-2xl object-cover shadow-sm" widths={[500, 900]} sizes="(min-width: 1024px) 40vw, 90vw" loading="lazy" />
        <dl class="mt-6 grid grid-cols-2 gap-3">
          {personal.map((p) => (
            <div class="rounded-xl border border-frost bg-white px-4 py-3">
              <dt class="text-[0.7rem] uppercase tracking-wide text-ink/50">{p.label}</dt>
              <dd class="mt-0.5 font-medium">{p.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="reveal">
        <h3 class="font-display text-lg font-semibold uppercase tracking-wide text-ink/80">Werdegang im Pferdesport</h3>
        <ol class="mt-6 space-y-6 border-l-2 border-frost pl-6">
          {career.map((c) => (
            <li class="relative">
              <span class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full border-2 border-glacier bg-snow"></span>
              <div class="font-display text-sm font-semibold uppercase tracking-wide text-glacier">{c.period}</div>
              <div class="mt-1 text-ink/80">{c.text}</div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ===== RESULTATE ===== -->
  <section id="resultate" class="scroll-mt-16 bg-white py-24">
    <div class="mx-auto max-w-6xl px-5">
      <div class="reveal max-w-2xl">
        <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Resultate</p>
        <h2 class="mt-3 text-3xl font-bold sm:text-5xl">Die erfolgreichsten Gespanne</h2>
        <p class="mt-4 text-lg text-ink/70">Karriere-Übersicht 1996–2022.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2">
        {topHorses.map((h) => (
          <div class="reveal rounded-2xl border border-frost bg-snow p-6 transition hover:border-glacier/40 hover:shadow-sm">
            <div class="flex items-baseline justify-between">
              <h3 class="text-xl font-semibold">{h.name}</h3>
              <span class="text-sm text-glacier">{h.years}</span>
            </div>
            <p class="mt-2 text-ink/75">{h.note}</p>
            {(h.trainer || h.owner) && (
              <p class="mt-3 text-sm text-ink/55">
                {h.owner}{h.owner && h.trainer ? ' · ' : ''}{h.trainer && `Trainer ${h.trainer}`}
              </p>
            )}
          </div>
        ))}
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="reveal">
          <h3 class="font-display text-lg font-semibold uppercase tracking-wide text-ink/80">Siege nach Pferd</h3>
          <div class="mt-5 space-y-3">
            {ranked.map((r) => {
              const wins = Number(r[2]);
              const starts = Number(r[1]);
              const pct = Math.round((wins / starts) * 100);
              return (
                <div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-medium">{r[0]}</span>
                    <span class="text-ink/55">{wins} / {starts}</span>
                  </div>
                  <div class="mt-1.5 h-2.5 overflow-hidden rounded-full bg-frost">
                    <div class="stat-bar h-full rounded-full bg-glacier" data-bar={pct} style="width:0%"></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="reveal flex">
          <div class="flex flex-col justify-center rounded-2xl bg-ink p-8 text-snow">
            <span class="font-display text-6xl font-bold text-gold" data-count="11" data-suffix="×">11×</span>
            <h3 class="mt-3 font-display text-xl font-semibold">König vom Engadin</h3>
            <p class="mt-2 text-snow/75">
              Der jährliche Titel der Credit Suisse / UBS Skikjöring Trophy geht an
              den erfolgreichsten Fahrer der Saison. Köbi Broger gewann die Krone
              elf Mal, ein bis heute prägender Rekord am White Turf.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PARALLAX DIVIDER ===== -->
  <section class="relative isolate flex h-[55vh] min-h-[360px] items-center justify-center overflow-hidden">
    <Image
      src={photo('race-1.jpg')}
      alt=""
      class="parallax-img -z-10"
      widths={[1200, 2000]}
      sizes="100vw"
      loading="lazy"
      data-parallax="0.22"
      data-zoom="0.12"
    />
    <div class="absolute inset-0 -z-10 bg-ink/55"></div>
    <div data-parallax="-0.12">
      <blockquote class="reveal mx-auto max-w-3xl px-6 text-center text-snow">
        <p class="font-display text-2xl font-medium leading-snug sm:text-4xl">
          „Der erste Flachländer, der in die Domäne der Engadiner einbrach.“
        </p>
        <footer class="mt-5 text-sm uppercase tracking-[0.25em] text-snow/70">White Turf · St. Moritz</footer>
      </blockquote>
    </div>
  </section>

  <!-- ===== STATISTIK ===== -->
  <section id="statistik" class="mx-auto max-w-6xl scroll-mt-16 px-5 py-24">
    <div class="reveal max-w-2xl">
      <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Statistik</p>
      <h2 class="mt-3 text-3xl font-bold sm:text-5xl">Alle Starts, 1996–2022</h2>
      <p class="mt-4 text-lg text-ink/70">61 Starts · 24 Siege · 11 Titel.</p>
    </div>

    <div class="reveal mt-10 overflow-x-auto rounded-2xl border border-frost bg-white">
      <table class="w-full min-w-[640px] text-sm">
        <thead>
          <tr class="bg-ink text-snow">
            {stats.columns.map((c, i) => (
              <th class:list={['px-4 py-3 font-display font-medium uppercase tracking-wide', i === 0 ? 'text-left' : 'text-center']}>{c}</th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-frost">
          {stats.rows.map((row) => (
            <tr class="transition hover:bg-snow">
              {row.map((cell, i) => (
                <td class:list={['px-4 py-3', i === 0 ? 'text-left font-medium' : 'text-center', i === 2 && cell ? 'font-semibold text-glacier' : '']}>{cell}</td>
              ))}
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-ink bg-frost/40 font-display font-semibold">
            {stats.total.map((cell, i) => (
              <td class:list={['px-4 py-3', i === 0 ? 'text-left' : 'text-center']}>{cell}</td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- ===== IMPRESSIONEN ===== -->
  <section id="impressionen" class="scroll-mt-16 bg-white py-24">
    <div class="mx-auto max-w-6xl px-5">
      <div class="reveal max-w-2xl">
        <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Impressionen</p>
        <h2 class="mt-3 text-3xl font-bold sm:text-5xl">Bilder vom Eis</h2>
        <p class="mt-4 text-lg text-ink/70">Rennszenen vom White Turf St. Moritz. Zum Vergrössern anklicken.</p>
      </div>
      <div class="mt-10 grid auto-rows-[160px] grid-cols-2 gap-3 sm:auto-rows-[190px] md:grid-cols-4">
        {gallery.map((g) => (
          <button
            type="button"
            class:list={['gallery-item reveal group relative overflow-hidden rounded-2xl', g.cls]}
            data-full={galleryFull[g.name]}
            data-caption={g.alt}
            aria-label={`Bild vergrössern: ${g.alt}`}
          >
            <Image
              src={photo(g.name)}
              alt={g.alt}
              class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
              widths={[400, 700, 1000]}
              sizes="(min-width: 768px) 25vw, 50vw"
              loading="lazy"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox overlay -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Bildansicht">
    <button id="lightbox-close" class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-snow transition hover:bg-white/20" aria-label="Schliessen">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18" /></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-snow transition hover:bg-white/20 sm:left-6" aria-label="Vorheriges Bild">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6" /></svg>
    </button>
    <button id="lightbox-next" class="absolute right-3 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-snow transition hover:bg-white/20 sm:right-6" aria-label="Nächstes Bild">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" /></svg>
    </button>
    <figure class="flex flex-col items-center gap-3">
      <img id="lightbox-img" src="" alt="" />
      <figcaption id="lightbox-cap" class="text-sm text-snow/70"></figcaption>
    </figure>
  </div>

  <!-- ===== SPONSORING ===== -->
  <section id="sponsoring" class="scroll-mt-16 bg-white py-24">
    <div class="mx-auto max-w-6xl px-5">
      <div class="reveal max-w-2xl">
        <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Sponsoring</p>
        <h2 class="mt-3 text-3xl font-bold sm:text-5xl">Engagement für den Nachwuchs</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink/75">{sponsoring.intro}</p>
      </div>
      <div class="reveal mt-10 grid gap-5 sm:grid-cols-2">
        {sponsoring.blocks.map((b) => (
          <div class="rounded-2xl border border-frost bg-snow p-6">
            <h3 class="font-display text-lg font-semibold text-glacier-deep">{b.company}</h3>
            <p class="mt-2 text-ink/75">{b.supports}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="bg-ink text-snow">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="text-center font-display text-sm uppercase tracking-[0.25em] text-snow/60">Partner &amp; Sponsoren</h2>
      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {partners.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener"
            title={p.name}
            class:list={[
              'flex h-20 items-center justify-center rounded-xl border p-4 transition hover:scale-[1.03]',
              p.dark ? 'border-white/15 bg-ink' : 'border-frost bg-white',
            ]}
          >
            <img src={logo(p.logo)} alt={p.name} class="max-h-12 max-w-[85%] w-auto object-contain" loading="lazy" />
          </a>
        ))}
      </div>
      <div class="mt-14 flex flex-col items-center gap-1 border-t border-white/10 pt-8 text-center text-sm text-snow/60">
        <p class="font-display text-base tracking-wide text-snow/90">Jakob (Köbi) Broger</p>
        <p>{profile.location}</p>
        <p class="mt-2 text-xs">© 2026 Jakob Broger · Skikjöringfahrer</p>
      </div>
    </div>
  </footer>
</Base>

<script>
  // Reveal sections as they scroll into view.
  const els = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
  );
  els.forEach((el) => io.observe(el));

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Count-up: animate [data-count] numbers from 0 when they enter view.
  const countIO = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = parseFloat(el.getAttribute('data-count')) || 0;
        const suffix = el.getAttribute('data-suffix') || '';
        countIO.unobserve(el);
        if (reduceMotion) {
          el.textContent = target + suffix;
          return;
        }
        const dur = 1300;
        let startTime = null;
        const step = (now) => {
          if (startTime === null) startTime = now;
          const p = Math.min(1, (now - startTime) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    },
    { threshold: 0.5 }
  );
  document.querySelectorAll('[data-count]').forEach((el) => {
    if (!reduceMotion) el.textContent = '0';
    countIO.observe(el);
  });

  // Grow the win-rate bars from 0 to their target width when in view.
  const barIO = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        e.target.style.width = e.target.getAttribute('data-bar') + '%';
        barIO.unobserve(e.target);
      });
    },
    { threshold: 0.4 }
  );
  document.querySelectorAll('.stat-bar').forEach((el) => barIO.observe(el));

  // Parallax engine: per-layer vertical drift, scroll-zoom, fade, and (on the
  // hero) pointer tracking — composed into one transform per element.
  const layers = [...document.querySelectorAll('[data-parallax]')].map((el) => ({
    el,
    speed: parseFloat(el.getAttribute('data-parallax')) || 0,
    zoom: parseFloat(el.getAttribute('data-zoom')) || 0,
    fade: el.hasAttribute('data-fade'),
    pointer: parseFloat(el.getAttribute('data-pointer')) || 0,
    section: el.closest('section') || el.parentElement,
  }));
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const hero = document.getElementById('top');
  let pointerX = 0; // -1..1 relative to hero center
  let pointerY = 0;
  let ticking = false;

  const render = () => {
    const vh = window.innerHeight;
    for (const L of layers) {
      const rect = L.section.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > vh + 200) continue; // skip offscreen
      const center = rect.top + rect.height / 2 - vh / 2;
      const prog = center / vh; // ~0 when centered, ±1 near edges
      let x = 0;
      let y = -center * L.speed;
      if (L.pointer) {
        x += pointerX * L.pointer;
        y += pointerY * L.pointer * 0.55;
      }
      let t = `translate3d(${x.toFixed(1)}px, ${y.toFixed(1)}px, 0)`;
      if (L.zoom) t += ` scale(${(1 + Math.min(Math.abs(prog), 1) * L.zoom).toFixed(3)})`;
      L.el.style.transform = t;
      if (L.fade) L.el.style.opacity = Math.max(0, 1 - Math.abs(prog) * 1.5).toFixed(3);
    }
    ticking = false;
  };
  const schedule = () => {
    if (!ticking) {
      requestAnimationFrame(render);
      ticking = true;
    }
  };

  if (!reduceMotion && layers.length) {
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', render);
    // Pointer parallax on the hero (desktop / fine-pointer only).
    if (fine && hero) {
      hero.addEventListener('pointermove', (e) => {
        const r = hero.getBoundingClientRect();
        pointerX = ((e.clientX - r.left) / r.width - 0.5) * 2;
        pointerY = ((e.clientY - r.top) / r.height - 0.5) * 2;
        schedule();
      });
      hero.addEventListener('pointerleave', () => {
        pointerX = 0;
        pointerY = 0;
        schedule();
      });
    }
    render();
  }

  // Lightbox: click a gallery tile to view it full-size, then page through
  // all photos with arrows, keyboard (← →), or swipe.
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCap = document.getElementById('lightbox-cap');
  const lbClose = document.getElementById('lightbox-close');
  const lbPrev = document.getElementById('lightbox-prev');
  const lbNext = document.getElementById('lightbox-next');

  const slides = [...document.querySelectorAll('.gallery-item')].map((b) => ({
    full: b.getAttribute('data-full'),
    cap: b.getAttribute('data-caption'),
  }));
  let current = 0;

  const preload = (i) => {
    const s = slides[(i + slides.length) % slides.length];
    if (s) new Image().src = s.full;
  };
  const show = (i) => {
    current = (i + slides.length) % slides.length; // wrap around
    const s = slides[current];
    lbImg.setAttribute('src', s.full);
    lbImg.setAttribute('alt', s.cap || '');
    lbCap.textContent = s.cap || '';
    preload(current + 1); // prefetch neighbours for snappy paging
    preload(current - 1);
  };
  const openLightbox = (i) => {
    show(i);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  };
  const closeLightbox = () => {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  };
  const next = () => show(current + 1);
  const prev = () => show(current - 1);

  document.querySelectorAll('.gallery-item').forEach((btn, i) =>
    btn.addEventListener('click', () => openLightbox(i))
  );
  lbClose?.addEventListener('click', closeLightbox);
  lbNext?.addEventListener('click', (e) => { e.stopPropagation(); next(); });
  lbPrev?.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
  lb?.addEventListener('click', (e) => {
    if (e.target === lb) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (!lb?.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowRight') next();
    else if (e.key === 'ArrowLeft') prev();
  });

  // Swipe navigation on touch devices.
  let touchX = null;
  lb?.addEventListener('touchstart', (e) => { touchX = e.changedTouches[0].clientX; }, { passive: true });
  lb?.addEventListener('touchend', (e) => {
    if (touchX === null) return;
    const dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 45) (dx < 0 ? next : prev)();
    touchX = null;
  }, { passive: true });
</script>
