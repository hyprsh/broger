---
const { title, lead } = Astro.props;
---

<section class="border-b border-frost bg-white">
  <div class="mx-auto max-w-6xl px-5 pb-12 pt-28">
    <p class="font-display text-xs uppercase tracking-[0.3em] text-glacier">Jakob Broger</p>
    <h1 class="mt-2 text-3xl font-bold sm:text-5xl">{title}</h1>
    {lead && <p class="mt-4 max-w-2xl text-lg text-ink/75">{lead}</p>}
  </div>
</section>
